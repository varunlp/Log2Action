# ═══════════════════════════════════════════════════════════════════
# LOG2ACTION — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=log2action_user
POSTGRES_PASSWORD=secretpassword
POSTGRES_DB=log2action_db
DATABASE_URL=postgresql://log2action_user:secretpassword@localhost:5432/log2action_db

# ── AI Provider ───────────────────────────────────────────────────
# Choose ONE provider. Only one should be active at a time.
#
# Option 1: "mock" — No API key needed. Uses built-in smart mock AI.
#   Good for: demos, office presentations, local testing.
#   RAG still works! Upload runbooks and the mock will use them.
#
# Option 2: "gemini" — Requires a Google Gemini API key.
#   Good for: production use with real AI analysis.
#
# Option 3 (future): "ollama" — Local LLM via Ollama.
#   Requires Ollama running locally.

AI_PROVIDER=mock

# ── Provider API Keys ─────────────────────────────────────────────
# Only fill in the key for the provider you selected above.

# For AI_PROVIDER=gemini:
# GEMINI_API_KEY=your_gemini_api_key_here

# For AI_PROVIDER=ollama (future):
# OLLAMA_BASE_URL=http://localhost:11434

# For AI_PROVIDER=openai (future):
# OPENAI_API_KEY=your_openai_api_key_here
