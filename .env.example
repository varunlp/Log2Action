# ═══════════════════════════════════════════════════════════════════
# LOG2ACTION — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=log2action_user
POSTGRES_PASSWORD=change_me_to_a_strong_database_password
POSTGRES_DB=log2action_db
# Use DATABASE_URL for managed cloud Postgres. If set, it overrides POSTGRES_* values.
# DATABASE_URL=postgresql://user:password@host:5432/log2action_db

# ── AI Provider ───────────────────────────────────────────────────
# Choose ONE provider. Only one should be active at a time.
#
# Option 1: "mock" — No API key needed. Uses built-in smart mock AI.
#   Good for: demos, office presentations, local testing.
#   RAG still works! Upload runbooks and the mock will use them.
#
# Option 2: "gemini" — Requires a Google Gemini API key.
#   Good for: production use with real AI analysis.
#
# Option 3 (future): "ollama" — Local LLM via Ollama.
#   Requires Ollama running locally.

AI_PROVIDER=mock

# ── Provider API Keys ─────────────────────────────────────────────
# Only fill in the key for the provider you selected above.

# For AI_PROVIDER=gemini:
# GEMINI_API_KEY=your_gemini_api_key_here

# For AI_PROVIDER=ollama (future):
# OLLAMA_BASE_URL=http://localhost:11434

# For AI_PROVIDER=openai (future):
# OPENAI_API_KEY=your_openai_api_key_here

# ── Security ──────────────────────────────────────────────────────
ENVIRONMENT=development

# IMPORTANT: use a unique 32+ character value in production.
JWT_SECRET_KEY=replace_with_a_unique_32_plus_character_secret

# Comma-separated list of allowed frontend origins for CORS.
# Use "*" for development, specific domains for production.
# Example: CORS_ORIGINS=https://app.log2action.com,https://admin.log2action.com
CORS_ORIGINS=http://localhost,http://localhost:5173

# Host header allow-list for production deployments.
# Example: ALLOWED_HOSTS=app.log2action.com,api.log2action.com
ALLOWED_HOSTS=*

# Optional one-time bootstrap admin for first deploy. Remove after the admin exists.
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=UseA_Strong_InitialPassword123

# Local developer convenience only. In production, use bootstrap admin instead.
FIRST_USER_AUTO_ADMIN=true

# Frontend build setting. Leave empty when nginx proxies /api on the same domain.
# VITE_API_URL=https://api.log2action.com

# Upload limit in bytes. Default is 10485760 (10 MB).
MAX_UPLOAD_BYTES=10485760
