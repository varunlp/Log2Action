# ═══════════════════════════════════════════════════════════════════
# LOG2ACTION — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ===================================================================
# 🌍 ENVIRONMENT SWITCHER (development or production)
# ===================================================================
# Use "development" for local testing (enables some insecure conveniences).
# Use "production" for cloud/live deployments (enforces security constraints).
ENVIRONMENT=development

# ===================================================================
# 🔒 REQUIRED SECRETS (Must be set for all environments)
# ===================================================================
# Generate a secure key (e.g., using `openssl rand -hex 32`)
JWT_SECRET_KEY=your_secure_32_character_jwt_secret_here

# Database password (make it strong!)
POSTGRES_PASSWORD=your_secure_postgres_password_here

# ===================================================================
# 💾 DATABASE SETTINGS
# ===================================================================
POSTGRES_USER=log2action_user
POSTGRES_DB=log2action_db
# Use DATABASE_URL for managed cloud Postgres. If set, it overrides POSTGRES_* values.
# DATABASE_URL=postgresql://user:password@host:5432/log2action_db

# ===================================================================
# 🤖 AI PROVIDER CONFIGURATION
# ===================================================================
# Choose ONE provider: "mock", "gemini", "ollama", "openai"
AI_PROVIDER=mock

# Provide the corresponding API key based on your choice above:
# GEMINI_API_KEY=your_gemini_api_key_here
# OLLAMA_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=your_openai_api_key_here

# ===================================================================
# 🚀 PRODUCTION DEPLOYMENT SETTINGS (Required if ENVIRONMENT=production)
# ===================================================================
# Comma-separated list of allowed frontend origins for CORS.
# Example: CORS_ORIGINS=https://app.log2action.com,https://admin.log2action.com
CORS_ORIGINS=*

# Host header allow-list for production deployments.
# Example: ALLOWED_HOSTS=app.log2action.com,api.log2action.com
ALLOWED_HOSTS=*

# ===================================================================
# 👤 ADMIN BOOTSTRAPPING
# ===================================================================
# Optional one-time bootstrap admin for first deploy. Remove after the admin exists.
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=UseA_Strong_InitialPassword123

# ===================================================================
# 🛠️ DEVELOPMENT CONVENIENCES (Ignored in production)
# ===================================================================
# Auto-create this admin user on startup in development mode.
ENABLE_DEV_ADMIN=true
DEV_ADMIN_EMAIL=admin@log2action.local
DEV_ADMIN_PASSWORD=AdminPass1234

# Auto-make the first registered user an admin (Local convenience only).
FIRST_USER_AUTO_ADMIN=true

# Frontend build setting. Leave empty when nginx proxies /api on the same domain.
# VITE_API_URL=https://api.log2action.com

# Upload limit in bytes. Default is 10485760 (10 MB).
MAX_UPLOAD_BYTES=10485760